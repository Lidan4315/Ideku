@model IEnumerable<Ideku.Models.Idea>

@{
    ViewData["Title"] = "My Ideas";
}

<div class="card">
    <div class="card-header">
        <h4>My Submitted Ideas</h4>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Actions</th>
                        <th>Idea ID</th>
                        <th>Idea Title</th>
                        <th>Idea Description</th>
                        <th>Saving Cost</th>
                        <th>Saving Cost Validated</th>
                        <th>Submission Date</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <a href="#" class="btn btn-sm btn-outline-primary" title="View Details">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                                <td>@item.Id</td>
                                <td>@item.IdeaName</td>
                                <td>@item.IdeaIssueBackground</td>
                                <td>@item.SavingCost?.ToString("C", new System.Globalization.CultureInfo("en-US"))</td>
                                <td>@item.SavingCostValidated?.ToString("C", new System.Globalization.CultureInfo("en-US"))</td>
                                <td>@item.SubmittedDate.ToString("yyyy-MM-dd")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center">You haven't submitted any ideas yet.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>